{
  "extends": "./.nuxt/tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/types/*": ["types/*"],
      "~types/*": ["types/*"],
      "~/types": ["types/index.ts"]
    }
  },
  "include": [".nuxt/**/*", "types/**/*", "**/*.ts", "**/*.vue"],
  "exclude": ["tests", "tests/**/*", "**/*.spec.ts", "**/*.test.ts", "test-results", "node_modules"]
}
