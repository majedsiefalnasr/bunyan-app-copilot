# Bunyan frontend — copy to `.env` for local dev:
#   cp .env.example .env
#
# Nuxt exposes only variables prefixed with NUXT_PUBLIC_ to the browser.

# Laravel API origin (no trailing slash). REST routes live under /api/v1 on the backend.
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: set when the Nuxt app is served behind a different public URL (SSR, proxies).
# NUXT_PUBLIC_SITE_URL=http://localhost:3000
