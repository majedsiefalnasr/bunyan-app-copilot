includes:
  - vendor/phpstan/phpstan/conf/bleedingEdge.neon
  - vendor/larastan/larastan/extension.neon

parameters:
  level: 5
  paths:
    - app
    - routes
    - database/factories
    - database/seeders
  tmpDir: build/phpstan
  typeAliases:
    ID: 'int|string'
  treatPhpDocTypesAsCertain: false
